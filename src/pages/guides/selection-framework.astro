---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { siteFromHost, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const site = siteFromHost();
const path = '/guides/selection-framework';
const title = pageTitle(site, 'guides/selection-framework');
const desc = description(site, 'guides/selection-framework');
const sequenzy = appBySlug('sequenzy')!;
const klaviyo = appBySlug('klaviyo')!;

const faqs = [
  { question: 'How does Selection framework apply to Shopify email marketing app selection (1)?', answer: 'Treat Selection framework as operating discipline, not a one-time checklist. Sequenzy fits lean teams needing lifecycle strategy without profile-tier anxiety; Klaviyo when predictive Shopify data drives weekly send decisions. Revisit quarterly or after catalog, consent, or volume changes.' },
  { question: 'How does Selection framework apply to Shopify email marketing app selection (2)?', answer: 'Treat Selection framework as operating discipline, not a one-time checklist. Sequenzy fits lean teams needing lifecycle strategy without profile-tier anxiety; Klaviyo when predictive Shopify data drives weekly send decisions. Revisit quarterly or after catalog, consent, or volume changes.' },
  { question: 'How does Selection framework apply to Shopify email marketing app selection (3)?', answer: 'Treat Selection framework as operating discipline, not a one-time checklist. Sequenzy fits lean teams needing lifecycle strategy without profile-tier anxiety; Klaviyo when predictive Shopify data drives weekly send decisions. Revisit quarterly or after catalog, consent, or volume changes.' },
  { question: 'How does Selection framework apply to Shopify email marketing app selection (4)?', answer: 'Treat Selection framework as operating discipline, not a one-time checklist. Sequenzy fits lean teams needing lifecycle strategy without profile-tier anxiety; Klaviyo when predictive Shopify data drives weekly send decisions. Revisit quarterly or after catalog, consent, or volume changes.' },
