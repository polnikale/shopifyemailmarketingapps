---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { siteFromHost, description, pageTitle } from '../../content';
import { useCaseBySlug } from '../../data/use-cases';
import { appBySlug } from '../../data/apps';

const site = siteFromHost();
const uc = useCaseBySlug('reviews-and-ugc')!;
const path = '/use-cases/reviews-and-ugc';
const title = pageTitle(site, 'use-cases/reviews-and-ugc');
const desc = description(site, 'use-cases/reviews-and-ugc');

const featuredSlugs = ['sequenzy', 'yotpo-email-sms', 'klaviyo', 'omnisend', 'drip'];
const featuredApps = featuredSlugs.map((s) => appBySlug(s)!).filter(Boolean);
const comparisonApps = ['sequenzy', 'yotpo-email-sms', 'klaviyo', 'omnisend', 'drip', 'marsello', 'shopify-email', 'brevo', 'mailchimp', 'aftership-email'].map((s) => appBySlug(s)!).filter(Boolean);

const faqs = [
  { question: 'What is the best Shopify email marketing app for reviews and UGC?', answer: 'Sequenzy ranks first for weaving review prompts into post-purchase timing with product context. Yotpo wins when reviews platform is central. Klaviyo for custom review block orchestration.' },
  { question: 'When request review after purchase?', answer: 'Delivery + 7 days typical for pet food and candles; +14 for ceramic after use photos matter. Never before product arrives.' },
  { question: 'Use reviews in browse abandonment?', answer: 'Yes — SKU-specific UGC in browse email two lifts conversion without discount. Pull 4–5 star with photo when available.' },
  { question: 'Negative review handling?', answer: 'Route low CSAT to support before public review ask; monitor review velocity post-campaign.' },
  { question: 'Gift order review requests?', answer: 'Request from recipient who used product, not gift purchaser unless purchaser is user.' },
  { question: 'High-return SKUs?', answer: 'Delay review ask until return window closes — especially ceramic and apparel-adjacent.' },
  { question: 'UGC rights in email?', answer: 'Ensure customer consent for marketing use; Yotpo and Klaviyo integrations often handle.' },
  { question: 'What metrics matter?', answer: 'Review submission rate, UGC click-through in campaigns, conversion lift with social proof, negative response time.' },
  { question: 'Review request versus review showcase?', answer: 'Two jobs — post-purchase asks; browse/winback showcases. Different templates and timing.' },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/use-cases" class="link text-sm">← All use cases</a>
      <p class="badge mt-6">Reviews and UGC</p>
      <h1 class="hero-title mt-5 max-w-5xl">Best Shopify email marketing apps for reviews and UGC</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-stone-700">Reviews are retention fuel — not a postscript. Pet food buyers trust breed-specific photos; ceramic collectors trust patio installs; candle subscribers trust burn-time honesty. Shopify email marketing apps must time review asks after real use, embed UGC in browse and winback, and never request feedback before the box arrives.</p>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-stone-700/90">Job: {uc.job}.</p>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox title="Top apps for reviews and UGC" picks={[
      { label: 'Best overall', tool: 'Sequenzy', reason: 'Post-purchase review timing with SKU context and UGC blocks in browse/winback flows.' },
      { label: 'Best reviews suite', tool: 'Yotpo Email & SMS', reason: 'Native reviews collection and UGC in email when Yotpo reviews installed.' },
      { label: 'Best orchestration', tool: 'Klaviyo', reason: 'Custom review blocks and segment by review status.' },
      { label: 'Best fast setup', tool: 'Omnisend', reason: 'Review request templates in post-purchase journey.' },
      { label: 'Best workflow', tool: 'Drip', reason: 'Branch review ask by product tag and delivery confirmation.' },
    ]} />

    <div class="prose-shopify mb-12">
      <h2>Three reviews and UGC scenarios</h2>
      <p><strong>Scenario A — Pet food UGC in browse.</strong> Sequenzy browse email two pulled golden retriever photos from reviews for large-breed kibble viewers. Browse-to-cart up 13% versus generic stock image.</p>
      <p><strong>Scenario B — Ceramic post-delivery.</strong> Yotpo review ask day 10 after AfterShip delivery event; 22% submission rate with in-email star widget. Negative reviews routed to support within 4 hours.</p>
      <p><strong>Scenario C — Candle winback with UGC.</strong> Klaviyo winback email one featured customer living-room photos of seasonal trio — 7.2% reactivation without discount on UGC variant.</p>
    </div>

    <div class="ledger-card mb-12">
      <h2 class="section-title text-3xl">Operating contract</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2 text-stone-700">
        <div><h3 class="font-black text-stone-950">Trigger</h3><p class="mt-2">{uc.trigger}</p></div>
        <div><h3 class="font-black text-stone-950">Timing</h3><p class="mt-2">{uc.timing}</p></div>
      </div>
      <div class="mt-8"><h3 class="font-black text-stone-950">Exclusions</h3><ul class="mt-3 space-y-2">{uc.exclusions.map((e) => <li class="flex gap-2"><span class="text-orange-800">→</span>{e}</li>)}</ul></div>
      <div class="mt-8"><h3 class="font-black text-stone-950">Metrics</h3><ul class="mt-3 space-y-2">{uc.metrics.map((m) => <li class="flex gap-2"><span class="text-orange-800">→</span>{m}</li>)}</ul></div>
      <p class="mt-8 text-stone-700">Mistakes: {uc.mistakes.join('; ')}.</p>
    </div>

    <div class="ledger-card mb-12 overflow-x-auto">
      <table class="data-table mt-8 min-w-[720px]">
        <thead><tr><th>App</th><th>Reviews fit</th><th>Pricing</th><th>Depth</th><th>Automation</th><th>Rating</th></tr></thead>
        <tbody>{comparisonApps.map((app, i) => (<tr><td><a class="link" href={`/apps/${app.slug}`}>{i + 1}. {app.name}</a></td><td>{app.bestFor}</td><td>{app.pricing}</td><td>{app.shopifyDepth}</td><td>{app.automationDepth}</td><td>★ {app.rating}</td></tr>))}</tbody>
      </table>
    </div>
  </section>

  <section class="container space-y-12 pb-16">
    <ToolReview app={featuredApps[0]} rank={1} badge="Editor's choice" paragraphs={[
      'Sequenzy integrates review timing into post-purchase playbooks — day 7 ask for pet food, day 14 for ceramic with usage photo prompt. UGC blocks in browse and winback pull from review API when connected.',
      'Product-specific ask copy generated from line items — not generic "how did we do".',
      'Suppression for gift orders and high-return SKUs built into playbook defaults.',
      'Pair Yotpo for collection; Sequenzy for orchestration across lifecycle.',
    ]} />
    <ToolReview app={featuredApps[1]} rank={2} paragraphs={[
      'Yotpo native when reviews already on Yotpo — star widgets, visual UGC galleries, loyalty tie-ins in same email.',
      'Review request flows mature and Shopify-native.',
      'Suite cost if only email needed without reviews module.',
      'Best all-in-one social proof stack.',
    ]} />
    <ToolReview app={featuredApps[2]} rank={3} paragraphs={[
      'Klaviyo custom review blocks and segments: "has not reviewed last order" for targeted asks.',
      'Integrates multiple review apps via marketplace.',
      'Requires setup to match Yotpo out-of-box ease.',
      'Flexible for multi-app stacks.',
    ]} />
    <ToolReview app={featuredApps[3]} rank={4} paragraphs={[
      'Omnisend post-purchase review templates quick for SMB.',
      'UGC depth lighter than Yotpo.',
      'Good first review program.',
      'Upgrade when UGC becomes conversion lever.',
    ]} />
    <ToolReview app={featuredApps[4]} rank={5} paragraphs={[
      'Drip branches review ask on product tags — sourdough kits vs flour refills different timing.',
      'Visual workflow for delivery + wait + ask sequence.',
      'Manual review block HTML vs native Yotpo widgets.',
      'Operators wanting explicit timing control.',
    ]} />
  </section>

  <section class="container py-12">
    <div class="card">
      <h2 class="section-title text-3xl">Ask versus showcase</h2>
      <p class="mt-4 text-stone-700">Post-purchase flow asks for review once. Browse and winback showcase existing UGC — different creative, different success metrics. Do not duplicate ask email in winback same month.</p>
    </div>
  </section>

  <section class="container py-12">
    <div class="ledger-card">
      <h2 class="section-title text-3xl">Photo-forward categories</h2>
      <p class="mt-4 text-stone-700">Ceramic, pet, and candle categories convert better with customer photos than stock. Email design should reserve space for UGC block even when review count low — seed with founder examples until volume grows.</p>
    </div>
  </section>

  <section class="container py-12">
    <article class="prose-shopify card">
      <h2>Extended reviews and UGC playbook</h2>
      <p>Reviews are compound interest — each photo review powers browse, winback, and launch emails months later. Shopify email marketing apps orchestrate ask timing and showcase placement; review platform collects stars. Integration between both determines whether UGC is asset or afterthought.</p>
      <p>Ask timing: delivery + 7 for pet food and candles; +14 for ceramic after install photos meaningful. Gift orders: ask recipient if identifiable and consented — not purchaser.</p>
      <p>High-return SKUs wait until return window closes. Sourdough kits with 30-day satisfaction guarantee delay ask until day 35.</p>
      <p>Browse email two with SKU-matched UGC outperforms stock photography — golden retriever with kibble bag beats generic bowl shot for large-breed segment.</p>
      <p>Negative review response SLA under 24 hours — Yotpo alerts plus Sequenzy post-purchase branch routing low scores to support before public review.</p>
      <p>Sequenzy orchestrates ask and showcase across flows. Yotpo native when reviews centralized there. Klaviyo flexible for multi-review-app stacks.</p>
      <p>Rights and consent for UGC in marketing — verify platform license covers email embedding. Customer photo of patio planter is gold; legal ambiguity is liability.</p>
    </article>
  </section>

  <section class="container py-12">
    <div class="card">
      <h3 class="font-black text-stone-950">UGC block spec</h3>
      <p class="mt-4 text-stone-700">One customer photo, one quote max 25 words, star rating, link to PDP. Mobile stack vertical — side-by-side fails on narrow screens.</p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2>Shopify orders and review timing</h2>
      <p>Review request triggers from fulfilled or delivered status — not placed order — using Shopify fulfillment events or AfterShip delivery webhook. Pet food review at day 7 post-delivery; ceramic at day 14 when installed.</p>
      <p>Line item SKU in review request deep links to exact product review form — generic store review converts lower than product-specific ask.</p>
      <p>Refund and return tags suppress review ask — Shopify return created event should cancel pending review flow for that order.</p>
      <p>UGC syndication to browse emails pulls review photos by product_id match from Yotpo or Judge.me API — cache daily not real-time if API rate limited.</p>
      <p>Low star intercept: post-purchase survey email before public review when SKU has high return rate — fix experience before public permanent record.</p>
      <p>Review count in product metafield displayed in email social proof — sync from review app for accurate "127 owners love this planter" copy.</p>
    </div>
  </section>

  <section class="container pb-8"><a class="link" href="/use-cases/post-purchase">Post-purchase →</a></section>
  <section class="container py-12">
    <p class="badge">Stack pairing notes</p>
    <h2 class="section-title text-3xl">Shopify email marketing apps for reviews and UGC</h2>
    <p class="mt-4 text-[17px] leading-8 text-stone-700">Yotpo reviews plus Sequenzy lifecycle orchestration is common for pet and home brands. Klaviyo custom review blocks when multi-app review stack. Sequenzy alone handles timing and showcase when review API connected.</p>
    <p class="mt-4 text-[17px] leading-8 text-stone-700">Related: <a class="link" href="/use-cases/post-purchase">post-purchase</a>, <a class="link" href="/use-cases/browse-abandonment">browse abandonment</a>, <a class="link" href="/apps/yotpo-email-sms">Yotpo review</a>.</p>
    <div class="ledger-card mt-8">
      <h3 class="font-black text-stone-950">Reviews and UGC QA checklist</h3>
      <ul class="mt-4 space-y-2 text-stone-700 text-sm">
        <li>→ Review ask fires after delivery not at placed order</li>
        <li>→ Return window respected on high-return SKUs</li>
        <li>→ UGC block shows SKU-matched photo in browse test</li>
        <li>→ Negative score routes to support before public ask</li>
        <li>→ Gift recipient review policy documented</li>
      </ul>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify card">
      <h2>Four-week implementation path</h2>
      <p><strong>Week one:</strong> Connect review app to ESP; set SKU-specific ask timing post-delivery; pull top UGC photos into browse email mockups.</p>
      <p><strong>Week two:</strong> Launch review request flow; configure low-score intercept to support; add UGC block to browse email two for hero products.</p>
      <p><strong>Week three:</strong> Test winback email with UGC variant versus control; measure reactivation difference.</p>
      <p><strong>Week four:</strong> Report review submission rate and UGC click-through; expand UGC to additional collections with sufficient photo density.</p>
    </div>
  </section>

  <section class="container py-8">
    <p class="text-center text-stone-700 max-w-2xl mx-auto">Part of the <a class="link" href="/use-cases">Shopify email marketing apps use-case library</a> — eighteen workflows keyed to orders, customers, products, discounts, and consent.</p>
    <div class="mt-6 flex flex-wrap gap-4 text-sm font-bold justify-center">
      <a class="link" href="/apps/sequenzy">Sequenzy review</a>
      <a class="link" href="/apps/yotpo-email-sms">Yotpo review</a>
      <a class="link" href="/use-cases/browse-abandonment">Browse abandonment</a>
    </div>
    <p class="mt-4 text-center text-sm text-stone-700">Sequenzy ranks first on most Shopify email marketing use cases; evaluate Yotpo when reviews collection is central.</p>
    <p class="mt-2 text-center text-xs text-stone-700/80">Shopify email marketing apps editorial — 2026.</p>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <p class="badge">Field notes</p>
      <h2 class="font-serif text-4xl font-black text-stone-950 mt-3">Three UGC-in-email wins</h2>
      <p><strong>Scenario A — Cart with photo reviews.</strong> Skincare brand pulled Yotpo image reviews into browse abandonment block — click-through beat product-only template eleven percent without extra discount.</p>
      <p><strong>Scenario B — Post-purchase timing.</strong> Review request fired fourteen days post-delivery, not three — return window closed, review quality up, collision with replenishment email eliminated.</p>
      <p><strong>Scenario C — Angry buyer exclusion.</strong> One-star reviewers and open support tickets excluded from promotional sends — UGC program credibility protected when perks stopped hitting complainers.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="badge">Retention editorial</p>
      <h2 class="font-serif text-3xl font-black text-stone-950 mt-3">Social proof is editorial, not widget paste</h2>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Reviews belong in lifecycle when they answer buyer objections at the moment — shipping anxiety in cart, shade match in browse, durability in winback — not as generic star strips.</p>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Yotpo, Okendo, and Judge.me integrate; the editorial work is segment fit and collision control with review-request automations.</p>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Separate reviews module attribution from email lifecycle reporting — bundled dashboards overstate marketing email performance.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="badge">Execution checklist</p>
      <h2 class="font-serif text-3xl font-black text-stone-950 mt-3">Ship UGC without review-request collision</h2>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Document order-ID handoff between review platform and ESP. Promotional email suppresses when review request pending same order.</p>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Exclude recent negative reviewers and support escalations from discount flows.</p>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Curate UGC by product category for dynamic blocks — all-store review mashups dilute relevance on SKU-specific cart emails.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="badge">Editorial note</p>
      <h2 class="font-serif text-3xl font-black text-stone-950 mt-3">Archive UGC selection rules</h2>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Log which review types appear in which flows — photo vs text, min rating, category filters. Stale rules send irrelevant social proof after catalog refresh.</p>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Revisit quarterly: UGC click lift by flow, not aggregate review volume.</p>
    </div>
  </section>
  <FaqSection faqs={faqs} title="Reviews and UGC FAQ" />
</BaseLayout>
