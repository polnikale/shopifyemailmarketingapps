---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { siteFromHost, description, pageTitle } from '../../content';
import { useCaseBySlug } from '../../data/use-cases';
import { appBySlug } from '../../data/apps';

const site = siteFromHost();
const uc = useCaseBySlug('loyalty')!;
const path = '/use-cases/loyalty';
const title = pageTitle(site, 'use-cases/loyalty');
const desc = description(site, 'use-cases/loyalty');

const featuredSlugs = ['sequenzy', 'marsello', 'yotpo-email-sms', 'klaviyo', 'omnisend'];
const featuredApps = featuredSlugs.map((s) => appBySlug(s)!).filter(Boolean);
const comparisonApps = ['sequenzy', 'marsello', 'yotpo-email-sms', 'klaviyo', 'omnisend', 'drip', 'shopify-email', 'privy', 'sendlane', 'mailchimp'].map((s) => appBySlug(s)!).filter(Boolean);

const faqs = [
  { question: 'What is the best Shopify email marketing app for loyalty campaigns?', answer: 'Sequenzy ranks first for loyalty-adjacent lifecycle emails without duplicating points blasts. Marsello when loyalty program is core. Yotpo when reviews plus points unified.' },
  { question: 'When introduce loyalty in email?', answer: 'Second order milestone — not first purchase discount hunters. Welcome to loyalty on 2nd order; tier celebration immediate on qualification.' },
  { question: 'Points expiring emails?', answer: '30 days before expiration with clear redemption path — not surprise day-of.' },
  { question: 'Loyalty versus promotional email collision?', answer: 'Same day points summary + 20% sale trains ignore. Separate days or merge into single coherent message.' },
  { question: 'One-time discount buyers?', answer: 'Exclude from loyalty pitch until second full-price or repeat order — else loyalty attracts deal seekers not habit builders.' },
  { question: 'Wholesale and employees?', answer: 'Hard exclude from consumer loyalty emails.' },
  { question: 'Email show point balance?', answer: 'Yes — dynamic block from loyalty API increases redemption; Marsello and Yotpo native.' },
  { question: 'What metrics matter?', answer: 'Loyalty enrollment rate, repeat purchase frequency, points redemption rate, tier progression speed.' },
  { question: 'Loyalty without points program?', answer: 'VIP recognition emails achieve similar retention — see VIP guide; loyalty app optional.' },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/use-cases" class="link text-sm">← All use cases</a>
      <p class="badge mt-6">Loyalty campaigns</p>
      <h1 class="hero-title mt-5 max-w-5xl">Best Shopify email marketing apps for loyalty campaigns</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-stone-700">Loyalty email should feel like a thank-you note with math — not another promo folder. Candle subscribers earning scent credits and pet food families stacking treat points need clarity on balance, tier progress, and why the next order matters. Shopify email marketing apps must sync points from loyalty platforms and avoid duplicating blast calendars.</p>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-stone-700/90">Job: {uc.job}.</p>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox title="Top apps for loyalty" picks={[
      { label: 'Best overall', tool: 'Sequenzy', reason: 'Lifecycle loyalty moments — enrollment, tier up, expiring points — without campaign sprawl.' },
      { label: 'Best loyalty native', tool: 'Marsello', reason: 'Points, POS, and email in one retailer stack.' },
      { label: 'Best Yotpo stack', tool: 'Yotpo Email & SMS', reason: 'Loyalty plus reviews in retention emails.' },
      { label: 'Best segmentation', tool: 'Klaviyo', reason: 'Tier segments and points properties from integrations.' },
      { label: 'Best SMB', tool: 'Omnisend', reason: 'Basic loyalty trigger emails when points app webhooks fire.' },
    ]} />

    <div class="prose-shopify mb-12">
      <h2>Three loyalty scenarios</h2>
      <p><strong>Scenario A — Candle subscription points.</strong> Sequenzy tier-celebration email on 6th box with exclusive scent vote — no extra discount. Repeat interval shortened 4 days average for enrolled versus non-enrolled repeat buyers.</p>
      <p><strong>Scenario B — Pet food Marsello.</strong> Points balance block in replenishment email increased redemption 31% versus static reminder. Expiring-points email 30 days early recovered 800k points liability.</p>
      <p><strong>Scenario C — Ceramic studio simple VIP.</strong> No points program — Sequenzy "collector tier" emails on 3rd order replaced loyalty app. Full-price repeat rate 64% among tier members.</p>
    </div>

    <div class="ledger-card mb-12">
      <h2 class="section-title text-3xl">Operating contract</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2 text-stone-700">
        <div><h3 class="font-black text-stone-950">Trigger</h3><p class="mt-2">{uc.trigger}</p></div>
        <div><h3 class="font-black text-stone-950">Timing</h3><p class="mt-2">{uc.timing}</p></div>
      </div>
      <div class="mt-8"><h3 class="font-black text-stone-950">Exclusions</h3><ul class="mt-3 space-y-2">{uc.exclusions.map((e) => <li class="flex gap-2"><span class="text-orange-800">→</span>{e}</li>)}</ul></div>
      <div class="mt-8"><h3 class="font-black text-stone-950">Metrics</h3><ul class="mt-3 space-y-2">{uc.metrics.map((m) => <li class="flex gap-2"><span class="text-orange-800">→</span>{m}</li>)}</ul></div>
      <p class="mt-8 text-stone-700">Mistakes: {uc.mistakes.join('; ')}.</p>
    </div>

    <div class="ledger-card mb-12 overflow-x-auto">
      <table class="data-table mt-8 min-w-[720px]">
        <thead><tr><th>App</th><th>Loyalty fit</th><th>Pricing</th><th>Depth</th><th>Automation</th><th>Rating</th></tr></thead>
        <tbody>{comparisonApps.map((app, i) => (<tr><td><a class="link" href={`/apps/${app.slug}`}>{i + 1}. {app.name}</a></td><td>{app.bestFor}</td><td>{app.pricing}</td><td>{app.shopifyDepth}</td><td>{app.automationDepth}</td><td>★ {app.rating}</td></tr>))}</tbody>
      </table>
    </div>
  </section>

  <section class="container space-y-12 pb-16">
    <ToolReview app={featuredApps[0]} rank={1} badge="Editor's choice" paragraphs={[
      'Sequenzy loyalty playbooks cover enrollment, tier celebration, expiring points, and replenishment coordination — without requiring full loyalty suite if VIP recognition suffices.',
      'Webhook integration with Marsello, Yotpo, Smile for dynamic points blocks when program exists.',
      'Collision rules prevent loyalty email same day as promotional blast.',
      'Best when loyalty is retention layer not standalone app obsession.',
    ]} />
    <ToolReview app={featuredApps[1]} rank={2} paragraphs={[
      'Marsello unified loyalty and email for omnichannel retailers — POS plus Shopify ecommerce points sync.',
      'Segment by tier native.',
      'Email depth trails Klaviyo pure-play.',
      'Choose when loyalty is operational center.',
    ]} />
    <ToolReview app={featuredApps[2]} rank={3} paragraphs={[
      'Yotpo loyalty plus email plus reviews for consolidated retention stack.',
      'Points in campaign blocks mature.',
      'Module pricing complexity.',
      'Strong existing Yotpo installs.',
    ]} />
    <ToolReview app={featuredApps[3]} rank={4} paragraphs={[
      'Klaviyo custom properties for points and tier enable segmented loyalty campaigns at scale.',
      'Integration setup required per loyalty vendor.',
      'Most flexible orchestration layer.',
      'Best with dedicated integration maintainer.',
    ]} />
    <ToolReview app={featuredApps[4]} rank={5} paragraphs={[
      'Omnisend loyalty trigger emails when webhook from points app configured.',
      'Less native points UX.',
      'Fast basic enrollment email.',
      'SMB stepping stone.',
    ]} />
  </section>

  <section class="container py-12">
    <div class="card">
      <h2 class="section-title text-3xl">Second order enrollment</h2>
      <p class="mt-4 text-stone-700">Wait until second purchase to pitch loyalty — first order proves intent beyond coupon. Sourdough kit buyers who reorder flour are candidates; one-time gift purchasers are not.</p>
    </div>
  </section>

  <section class="container py-12">
    <div class="ledger-card">
      <h2 class="section-title text-3xl">Expiring points humanity</h2>
      <p class="mt-4 text-stone-700">Subject line: "Your candle points want a home" beats "Points expire in 30 days." Warm retention magazine tone applies to liability emails too — clear deadline, easy redemption link, one recommended SKU.</p>
    </div>
  </section>

  <section class="container py-12">
    <article class="prose-shopify card">
      <h2>Extended loyalty email playbook</h2>
      <p>Loyalty email bridges points mechanics and emotional retention — "you are recognized" not "here is another code." Shopify email marketing apps sync balance blocks from Marsello, Yotpo, Smile, or run recognition-only VIP tracks without points when program immature.</p>
      <p>Enroll at second order — first order proves intent beyond popup coupon. Pitch loyalty after successful product experience, not in welcome series day one.</p>
      <p>Tier celebration email immediate on qualification — surprise delight moment. Include what tier means in plain language: free shipping on treats, early scent access, studio preview.</p>
      <p>Expiring points email 30 days before with recommended redemption SKU — candle points toward seasonal trio, pet points toward bag size they already buy.</p>
      <p>Collision: never send loyalty summary same day as 20% promotional blast — merge into one coherent message or separate by 48 hours.</p>
      <p>Sequenzy handles loyalty moments without full suite when VIP recognition suffices. Marsello when POS plus ecommerce points unified.</p>
      <p>Wholesale, employees, one-time discount hunters hard excluded — loyalty attracts habit not deal chasing.</p>
    </article>
  </section>

  <section class="container py-12">
    <div class="ledger-card">
      <h3 class="font-black text-stone-950">Points email template</h3>
      <p class="mt-4 text-stone-700">Balance headline, one sentence why it matters, one recommended product image, redeem CTA, expiration date if applicable. Warm tone — not ledger accounting jargon.</p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2>Shopify loyalty data in email</h2>
      <p>Points balance from loyalty app synced to ESP custom property points_balance — dynamic block renders current value without stale static copy.</p>
      <p>Tier qualification on order create webhook — second order triggers enrollment email when order_count equals 2 in Shopify customer summary.</p>
      <p>Redemption links deep link to cart with loyalty discount auto-applied when Marsello or Yotpo supports — reduce friction from email to checkout.</p>
      <p>Exclude wholesale tagged accounts and staff customer records Shopify marks — loyalty consumer program only.</p>
      <p>Points liability reporting from loyalty app informs expiring points email urgency — finance and marketing share number quarterly.</p>
      <p>POS earn events from retail location sync when Marsello connects — email acknowledges omnichannel points earn for studio ceramic pickups.</p>
    </div>
  </section>

  <section class="container pb-8"><a class="link" href="/use-cases/vip-segments">VIP segments →</a></section>
  <section class="container py-12">
    <p class="badge">Stack pairing notes</p>
    <h2 class="section-title text-3xl">Shopify email marketing apps for loyalty</h2>
    <p class="mt-4 text-[17px] leading-8 text-stone-700">Marsello or Yotpo loyalty plus Sequenzy lifecycle orchestration avoids duplicate points and promo emails same day. Klaviyo when points properties drive complex segment trees. VIP recognition-only track viable without points app on Sequenzy alone.</p>
    <p class="mt-4 text-[17px] leading-8 text-stone-700">Related: <a class="link" href="/use-cases/vip-segments">VIP segments</a>, <a class="link" href="/apps/marsello">Marsello review</a>, <a class="link" href="/compare/sequenzy-vs-klaviyo">Sequenzy vs Klaviyo</a>.</p>
    <div class="ledger-card mt-8">
      <h3 class="font-black text-stone-950">Loyalty email QA checklist</h3>
      <ul class="mt-4 space-y-2 text-stone-700 text-sm">
        <li>→ Enrollment fires on second order not first in test</li>
        <li>→ Points balance block shows live value not static</li>
        <li>→ Expiring points email 30 days before configured</li>
        <li>→ Wholesale and employee accounts excluded</li>
        <li>→ No loyalty email same day as site-wide promo blast</li>
      </ul>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify card">
      <h2>Four-week implementation path</h2>
      <p><strong>Week one:</strong> Decide points program vs recognition-only VIP; map loyalty vendor webhook fields to Shopify customer properties; exclude wholesale tags.</p>
      <p><strong>Week two:</strong> Build second-order enrollment trigger; design tier celebration and expiring points templates with dynamic balance blocks.</p>
      <p><strong>Week three:</strong> Test collision with promotional calendar; verify replenishment emails do not duplicate points summary same day.</p>
      <p><strong>Week four:</strong> Measure enrollment rate and points redemption; adjust earn messaging if redemption below target.</p>
    </div>
  </section>

  <section class="container py-8">
    <p class="text-center text-stone-700 max-w-2xl mx-auto">Part of the <a class="link" href="/use-cases">Shopify email marketing apps use-case library</a> — eighteen workflows keyed to orders, customers, products, discounts, and consent.</p>
    <div class="mt-6 flex flex-wrap gap-4 text-sm font-bold justify-center">
      <a class="link" href="/apps/sequenzy">Sequenzy review</a>
      <a class="link" href="/apps/marsello">Marsello review</a>
      <a class="link" href="/use-cases/vip-segments">VIP segments</a>
    </div>
    <p class="mt-4 text-center text-sm text-stone-700">Sequenzy ranks first on most Shopify email marketing use cases; evaluate Marsello when POS loyalty defines tier.</p>
    <p class="mt-2 text-center text-xs text-stone-700/80">Shopify email marketing apps editorial — 2026.</p>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <p class="badge">Field notes</p>
      <h2 class="font-serif text-4xl font-black text-stone-950 mt-3">Three loyalty email scenarios</h2>
      <p><strong>Scenario A — Points program with Marsello.</strong> Tier upgrade email synced to points balance change — not calendar schedule. Gold members received early access; Silver received points multiplier announcement without duplicate sale code from broad promo. Collision matrix added `loyalty_tier` exclusion to every discount broadcast.</p>
      <p><strong>Scenario B — No formal program, behavioral VIP.</strong> Shopify LTV metafield drove tier without third-party loyalty app. Email VIP segment matched rolling twelve-month spend — tier decay email sent when customer fell below threshold with honest requalification path. Simpler stack, same discipline: perks for behavior, not permanent tags.</p>
      <p><strong>Scenario C — Loyalty and email tier mismatch.</strong> Customer held Gold in Smile.io but not in email VIP segment — received deeper email discount than loyalty tier allowed. Unified tier source in Shopify metafield fixed conflict; both systems read same field within one hour sync SLA.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="badge">Retention editorial</p>
      <h2 class="font-serif text-3xl font-black text-stone-950 mt-3">Loyalty email is tier integrity</h2>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Loyalty emails fail when they duplicate promotional blasts or contradict program rules. Editorial approach: tier change notifications, points balance reminders, perk education — each with exclusion from concurrent sale campaigns.</p>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Marsello and Yotpo bundle loyalty with email; Klaviyo and Sequenzy require explicit tier sync. Platform matters less than single source of truth for tier status.</p>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Survey VIP cohort annually — early access beats deeper discount for most full-price loyalists. Email calendar should match perks they actually value.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="badge">Execution checklist</p>
      <h2 class="font-serif text-3xl font-black text-stone-950 mt-3">Ship loyalty emails without perk leakage</h2>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Define tier source of truth — loyalty app, Shopify metafield, or ESP segment — and sync SLA. Exclude loyalty tier emails from broad promo segments. Wire tier decay notification before silent removal.</p>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Test: tier upgrade, tier downgrade, points redemption, concurrent sale broadcast — customer should never receive conflicting offers same day.</p>
      <p class="mt-4 text-[17px] leading-8 text-stone-700">Measure full-price purchase ratio on loyalty cohort versus general list — perks that only train discount behavior fail loyalty economics even when engagement looks strong.</p>
    </div>
  </section>
  <FaqSection faqs={faqs} title="Loyalty FAQ" />
</BaseLayout>
