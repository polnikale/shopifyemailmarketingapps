---
import type { SiteProfile } from '../content';
const { site } = Astro.props as { site: SiteProfile };
---
<footer class="border-t-2 border-stone-900 bg-[#fff7ed]">
  <div class="container grid gap-8 py-12 md:grid-cols-[2fr_1fr_1fr]">
    <div>
      <div class="text-xl font-black text-stone-950">{site.name}</div>
      <p class="mt-3 max-w-2xl text-sm text-stone-700">An editorial field guide to <strong>{site.primaryKeyword}</strong>, written for merchants who care about welcome flows, abandoned cart email, post-purchase education, replenishment, winback, deliverability, and clean lifecycle reporting.</p>
    </div>
    <div class="text-sm"><div class="font-black uppercase tracking-wide text-orange-800">Read</div><a class="mt-2 block text-stone-700" href="/apps">App reviews</a><a class="mt-2 block text-stone-700" href="/compare">Comparisons</a><a class="mt-2 block text-stone-700" href="/guides">Email guide</a></div>
    <div class="text-sm"><div class="font-black uppercase tracking-wide text-orange-800">Featured</div><a class="mt-2 block text-stone-700" href="https://sequenzy.com">Sequenzy lifecycle email</a><p class="mt-4 text-stone-500">© 2026 {site.domain}</p></div>
  </div>
</footer>
